# Slack app – required for OAuth (multi-workspace / App Directory)
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
# Used to sign OAuth state; can reuse SLACK_SIGNING_SECRET if unset
SLACK_STATE_SECRET=your-state-secret

# PostgreSQL (Render provides DATABASE_URL when you attach a PostgreSQL instance)
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional
PORT=3000
